{#
/**
 * @file
 * Theme override to display the 'Webform with bg color' block.
 *
 * @see template_preprocess_block()
 */
#}
{%
  set classes = [
    'block-' ~ plugin_id|clean_class,
    'px-[28px] py-[40px]',
    'md:px-[50px] md:py-[70px]',
    'lg:px-[75px] lg:py-[80px]',
    'grid',
    'col-start-1 col-end-13',
  ]
%}
<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    <h2 class="h2 ph:text-[32px] md:text-[40px] lg:text-[46px] m-0 mb-[16px] text-white
      col-start-1 col-end-5
      ph:col-start-1 ph:col-end-12
      md:col-start-1 md:col-end-11
      lg:col-start-1 lg:col-end-10">{{ label }}</h2>
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    <div class="form-wrapper
      col-start-1 col-end-4
      ph:col-start-1 ph:col-end-10
      md:col-start-1 md:col-end-9
      lg:col-start-1 lg:col-end-7">
      {{ content }}
    </div>
  {% endblock %}
</div>

<style>
  .block-content--type-webform-with-background-color input {
    border-radius: 4px;
  }
  .block-content--type-webform-with-background-color h2.h2 {
    line-height: 1.2;
  }
  @media (max-width: 500px) {
    .block-content--type-webform-with-background-color h2.h2 {
      font-size: 32px;
      line-height: 1.2;
    }
  }
  .block-content--type-webform-with-background-color #wri-stay-informed-footer div[id^=edit-actions] input[type=submit] {
    height: 48px;
    margin-top: -1px;
    margin-right: -1px;
    border-bottom-right-radius: 4px;
    border-top-right-radius: 4px;
  }
</style>
