{#
/**
 * @file
 * Theme override to display the carousel with tabs block.
 *
 * @see template_preprocess_block()
 */
#}
{%
  set classes = [
    'block-' ~ configuration.provider|clean_class,
    'block-' ~ plugin_id|clean_class,
    'pt-15',
    'bg-neutral-200'
  ]
%}
<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    <div class="grid">
  <div class="layout__region layout__region--header">
    <h2{{ title_attributes.addClass('h3 top-border-thick') }}>{{ label }}</h2>
  </div>
    </div>
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    {{ content }}
  {% endblock %}
</div>
