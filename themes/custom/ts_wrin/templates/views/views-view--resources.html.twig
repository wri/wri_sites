{#
/**
 * @file
 * Theme override for the resources view template.
 *
 * @see template_preprocess_views_view()
 */
#}
{%
  set classes = [
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'resources-container',
  ]
%}

{% if header %}
  {{ header|without('extra_result', 'facets_summary') }}
{% endif %}
<div{{ attributes.addClass(classes) }}>
  {% if exposed %}
    {% set rendered = exposed|without('query', 'sort_by', 'topic')|render %}
    {% set form_opening_tag = rendered|preg_replace('/(<form[^>]*>).*/is', '$1') %}
    {% set form_guts = rendered|preg_replace('/<form[^>]*>/i', '') %}
    {% set form_closing_tag = '</form>' %}
    {{ form_opening_tag|raw }}
  {% endif %}
  {% if display_id == 'resources_page' %}
    <div class="container">
      <h1 class="h1 padding-vertical">{{ view.title }}</h1>
      {% if exposed %}
      {{ exposed.topic }}
      {% endif %}
    </div>
  {% endif %}
  <div class="resources-wrapper">
    <div class="container">

      {% if exposed %}
        <div class="view-filters">
          <button class="button black filters">{{ "Filters"|t }}</button>
          {% if exposed %}
          {{ exposed.query }}
          {{ exposed.sort_by }}
          {% endif %}
        </div>
      {% endif %}

      <div class="grid results-wrapper">
        <div class="results-sidebar padding-bottom">
          {% if exposed %}
            {{ form_guts|replace({'</form>': ''})|raw }}
          {% endif %}
        </div>
        <div class="results-body padding-bottom">
            <div class="view-header">
              {{ header.extra_result }}
              {{ header.facets_summary }}
            </div>
          {% if rows %}
            <div class="view-content">
              {{ rows }}
            </div>
          {% elseif empty %}
            <div class="view-empty">
              {{ empty }}
            </div>
          {% endif %}

          {% if pager %}
            {{ pager }}
          {% endif %}
          {% if more %}
            {{ more }}
          {% endif %}
        </div>
      </div>
      {% if footer %}
        <div class="view-footer">
          {{ footer }}
        </div>
      {% endif %}
    </div>
  </div>
{% if exposed %}
  {{ form_closing_tag|raw }}
{% endif %}
</div>
