<?php

/**
 * @file
 * Contains hsus_search.module.
 */

use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Field\BaseFieldDefinition;
use Drupal\Core\Form\FormStateInterface;
use Drupal\search_api\Plugin\views\query\SearchApiQuery;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_entity_base_field_info().
 */
function wri_search_entity_base_field_info(EntityTypeInterface $entity_type) {
  $fields = [];
  if ($entity_type->id() === 'taxonomy_term') {

    // Add a field that shows the parent of the term, or itself if no parent.
    $fields['term_parent_or_self'] = BaseFieldDefinition::create('term_parent_or_self')
      ->setName('term_parent_or_self')
      ->setLabel(t('Parent or Self'))
      ->setSetting('target_type', 'taxonomy_term')
      ->setComputed(TRUE)
      ->setClass('\Drupal\wri_common\WriCalculatedTexts')
      ->setDisplayConfigurable('view', FALSE)
      ->setCardinality(-1);

    // Add a field that shows the term only if a parent set.
    $fields['term_child_of_parent'] = BaseFieldDefinition::create('term_child_of_parent')
      ->setName('term_child_of_parent')
      ->setLabel(t('Is Child'))
      ->setSetting('target_type', 'taxonomy_term')
      ->setComputed(TRUE)
      ->setClass('\Drupal\wri_common\WriCalculatedTexts')
      ->setDisplayConfigurable('view', FALSE)
      ->setCardinality(-1);

  }
  if ($entity_type->id() === "node") {
    $fields['smart_topic_parent'] = BaseFieldDefinition::create('smart_topic_parent')
      ->setName('smart_topic_parent')
      ->setLabel(t('Smart Topic'))
      ->setSetting('target_type', 'taxonomy_term')
      ->setComputed(TRUE)
      ->setClass('\Drupal\wri_common\WriCalculatedTexts')
      ->setDisplayConfigurable('view', FALSE)
      ->setCardinality(-1);
  }

  return $fields;
}

/**
 * Implements hook_form_FORM_ID_alter() for views_exposed_form().
 */
function wri_search_form_views_exposed_form_alter(&$form, FormStateInterface $form_state) {
  // Custom integration for facets. When a Views exposed filter is modified on a
  // search results page it will lose any selected facets.
  // This adds hidden fields for each facet so their values are retained.
  // See: https://www.drupal.org/project/facets_pretty_paths/issues/3041314
  $storage = $form_state->getStorage();
  if (!isset($storage['view'])) {
    return;
  }
  $view = $storage['view'];
  if (!($view instanceof ViewExecutable)) {
    return;
  }
  $query_plugin = $view->getQuery();
  // Make sure the view is based on Search API and has the "Preserve facets"
  // option enabled, and that the Facets module is installed.
  $preserve_facets = !empty($query_plugin->options['preserve_facet_query_args'])
    && $query_plugin instanceof
    SearchApiQuery    && \Drupal::moduleHandler()->moduleExists('facets');
  if ($preserve_facets) {
    // Retrieve the facet source.
    $query = $query_plugin->getSearchApiQuery();
    $display_id = $query->getSearchId(FALSE);
    $facet_source_id = str_replace(':', '__', 'search_api:' . $display_id);
    $facet_source = \Drupal::entityTypeManager()
      ->getStorage('facets_facet_source')
      ->load($facet_source_id);
    if (!$facet_source) {
      return;
    }
    if ('facets_pretty_paths' == $facet_source->getUrlProcessorName()) {
      $form['#action'] = NULL;
    }
  }
}

/**
 * Implements hook_theme().
 */
function wri_search_theme() {
  return [
    'wri_search_menu' => [
      'variables' => [
        'search_nav_title' => '',
        'search_nav_description' => '',
        'search_nav_label' => '',
        'search_nav_id' => '',
        'search_nav_submit' => '',
        'search_nav_destination' => '/search',
      ],
    ],
    'wri_search_results_wrapper' => [
      'variables' => [
        'pager' => [],
        'search_form' => [],
        'search_results' => [],
        'search_results_title' => '',
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_hook().
 */
function wri_search_preprocess_facets_summary_item_list(&$variables) {
  // The facet summary doesn't work with Facets Pretty Path right now.
  // Urls look like this:
  // resources/topics/business-74?topic=74.
  // So attempting to unset the business topic doesn't strip out the ?topic=
  // part. I'm doing that here instead.
  // This may not be needed with a Drupal 11 upgrade, when we can start using
  // the latest Facets release, so re-evaluate then.
  if ($variables["facet_summary_id"] == 'summary') {
    $allowed = ['sort_by', 'page', 'query'];
    foreach ($variables["items"] as $delta => $facet) {
      if ($facet["value"]["#url"]->getRouteName() == 'view.resources.resources_page') {
        $options = $facet["value"]["#url"]->getOptions();
        $query = $options['query'];
        $options['query'] = array_intersect_key($query, array_flip($allowed));
        $variables["items"][$delta]["value"]['#url']->setOptions($options);
      }
    }
  }
}

/**
 * Implements hook_preprocess_hook() for bef_checkboxes.
 */
function wri_search_preprocess_bef_checkboxes(&$variables) {
  if (isset($variables["element"]["#name"]) == 'country') {
    // Get the parent values for region that have been set on the page.
    $request_stack = Drupal::requestStack();
    $current_request = $request_stack->getCurrentRequest();
    $current_filters = $current_request->query->all();
    $region = $current_filters['region'];
    $good_results = \Drupal::service('wri_search.pretty_facets_helper')->limitFacetsByParentId($region, \Drupal\Core\Render\Element::children($variables['element']));

    if (!empty($good_results)) {
      foreach (\Drupal\Core\Render\Element::children($variables['element']) as $item_number) {
        if (!in_array($item_number, $good_results)) {
          unset($variables['element'][$item_number]);
        }
      }
    }
  }
}
