<?php

/**
 * @file
 * Publication module code.
 */

use Drupal\node\NodeInterface;

/**
 * Implements hook_preprocess_hook().
 */
function wri_article_preprocess_wri_article_columns(&$context) {
  $node = \Drupal::routeMatch()->getParameter('node');
  if ($node instanceof NodeInterface) {
    if (isset($node->field_main_image->entity)) {
      $media = $node->field_main_image->entity;
      if ($media->hasField('field_attribution') && ($attribution = $media->get('field_attribution')) && !$attribution->isEmpty()) {
        $context['content']['byline']['attribution'] = [
          '#markup' => '<span class="cover-attribution">' . t('Cover Image by: @attribution', ['@attribution' => $attribution->getString()]) . '</span>',
          '#weight' => 10,
        ];
      }
    }
  }
}

/**
 * Preprocess for the wri_article_columns_b SFC layout.
 */
function wri_article_preprocess_wri_article_columns_b(array &$variables): void {
  // Show the label on "field_original_publish_date" if
  // "field_most_recently_updated_date" has a value.
  if (isset($variables["content"]["byline"]["field_most_recently_updated_date"][0])) {
    $variables["content"]["byline"]["field_original_publish_date"]["#label_display"] = 'inline';
    $variables["content"]["byline"]["node_post_date"]["#label_display"] = 'inline';
  }
  if (isset($variables["content"]["byline"]["field_original_publish_date"][0])) {
    $variables["content"]["byline"]["node_post_date"]["#access"] = FALSE;
  }
  // Default so Twig always has something.
  $variables['main_image_rendered'] = NULL;
  $variables['main_image_view_mode'] = 'default';

  $node = $variables['content']['#node'] ?? NULL;
  if (!$node instanceof NodeInterface) {
    return;
  }

  if (!$node->hasField('field_main_image') || $node->get('field_main_image')->isEmpty()) {
    return;
  }

  // Get the media view mode machine name.
  $view_mode = FALSE;
  if ($node->hasField('field_main_image_display') && !$node->get('field_main_image_display')->isEmpty()) {
    $view_mode = (string) $node->get('field_main_image_display')->value;
  }

  $media = $node->get('field_main_image')->entity;
  if (!$media) {
    return;
  }

  if (!$view_mode) {
    $variables['main_image_rendered'] = $variables["content"]["field_main_image"];
  }
  else {
    if ($view_mode == 'half_content') {
      $view_mode = 'half_hero';
    }
    $variables['main_image_view_mode'] = $view_mode;
    $variables['main_image_rendered'] = \Drupal::entityTypeManager()
      ->getViewBuilder('media')
      ->view($media, $view_mode);
  }

  $variables['border_position'] = 'after_byline';
  if ($variables['main_image_view_mode'] === 'half_hero' || $variables['main_image_view_mode'] == 'full_width_with_attribution') {
    $variables['border_position'] = 'before_body';
  }

  $variables['image_attribution'] = \Drupal::entityTypeManager()
    ->getViewBuilder('media')
    ->view($media, 'attribution');

  // Cache tags just to be safe.
  $variables['#cache']['tags'] = array_merge(
    $variables['#cache']['tags'] ?? [],
    $node->getCacheTags(),
    $media->getCacheTags()
  );
}
