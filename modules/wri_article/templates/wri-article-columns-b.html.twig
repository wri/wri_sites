{% if content %}

  {# Note: this sets the layout. The display mode for the main image is
     set in ts_wrin.theme in ts_wrin_preprocess_wri_article_columns_b() #}
  {% if content.category %}
    {# Default to full content. #}
    {% set region_display_value = 'full' %}
    {% set node = content['#node'] ?? null %}
    {% if node and node.hasField('field_main_image_display') %}
      {% set field = node.get('field_main_image_display') %}
      {% if field and not field.isEmpty() %}
        {% set region_display_value = field.value|clean_class %}
      {% endif %}
    {% endif %}
  {% endif %}

  {% set template_class = null %}
  {% if node and node.hasField('field_type') and not node.get('field_type').isEmpty() %}
    {% set type = node.get('field_type').entity %}
    {% set parent = type and not type.get('parent').isEmpty() ? type.get('parent').entity : null %}
    {% set parent_label = parent ? parent.label : null %}

    {% set map = {
      'Technical Perspectives': 'technical-perspective-template',
      'Update': 'project-update-template',
      'News': 'news-template',
      'Outcomes': 'project-update-template',
      'Snapshots': 'project-update-template'
    } %}

    {% set template_class = map[parent_label] ?? null %}
  {% endif %}

<div class="article article-b mt-4 page-layout-{{ region_display_value }} {{ template_class }}">
  {% if content.hero|render %}
  <div {{ region_attributes.hero.addClass('layout__region', 'layout__region--hero', 'layout__region--full') }}>
    <div class="centering">
    {{ content.hero }}
    </div>
  </div>
  {% endif %}

  <div{{ attributes.addClass('grid','article__title', 'margin-bottom-sm') }}>
    {% if content.category|render and not template_class and  region_display_value == 'half-content' %}
      {% if main_image_rendered %}
        <div class="half-image-wrapper">
          {{ main_image_rendered }}
        </div>
      {% endif %}
    {% endif %}

    {% if content.title|render %}
    <div {{ region_attributes.title.addClass('layout__region', 'layout__region--full', 'full-width', region_display_value) }}>

      {% if template_class %}
        <div class="utility-base btn-pill font-bold">{{ type.label }}</div>
        {{ content.title|without('field_type') }}
      {% else %}
        {{ content.title }}
      {% endif %}
      {% if node
        and node.hasField('field_intro')
        and node.get('field_intro').isEmpty()
        and node.body.summary|trim
      %}
        <div class="dek utility-xl">
          <p><span>{{ node.body.summary }}</span></p>
        </div>
      {% endif %}
    </div>
    {% endif %}

    <div {{ region_attributes.byline.addClass('layout__region', 'layout__region--full', 'full-width', 'pb-2', 'neutral-bottom-border') }}>
      {% if region_display_value == 'half-content' %}
        {{ content.bundle|without('field_relevant_project','field_tags') }}
      {% endif %}
    {{ content.byline }}
    </div>
  </div>

  {% if content.bundle|render or content.category|render or content.share|render %}
  <div class="article__meta grid">
    {% if content.bundle|render and template_class   %}
      <div {{ region_attributes.bundle.addClass('more-social-wrapper', 'layout__region', 'layout__region--bundle', 'layout__region--full') }}>
        {{ content.bundle|without('field_tags') }}
      </div>
    {% elseif content.bundle|render %}
      <div {{ region_attributes.bundle.addClass('more-social-wrapper', 'layout__region', 'layout__region--bundle', 'layout__region--full') }}>
        {% if region_display_value != 'half-content' %}
          {{ content.bundle|without('field_relevant_project') }}
        {% endif %}
      </div>
    {% endif %}

    {% if content.category|render and not template_class and region_display_value != 'hidden' and region_display_value != 'half-content' %}
      {# Main image layout. #}
      <div {{ region_attributes.category.addClass('main-image-wrapper', 'layout__region', 'layout__region--full') }}>
        {% if main_image_rendered %}
          {{ main_image_rendered }}
        {% endif %}
      </div>
    {% endif %}

    {% if content.share|render %}
    <div {{ region_attributes.share.addClass('layout__region', 'layout__region--share', 'right-sidebar') }}>
      {{ content.share }}

      {# Add mobile more items menu #}
      {% if content.left_sidebar|render|striptags|trim is not empty %}
        <div class="mobile more-on">
          <div class="field-label"><a href="#" class="more-open-close">{{ "More on"|t }}</a></div>
          <div class="more-on__items">
            {{ content.left_sidebar }}
          </div>
        </div>
      {% endif %}

    </div>
    {% endif %}
  </div>
  {% endif %}

  <div class="article__main grid margin-top-md">
    {% if content.left_sidebar|render|striptags|trim is not empty %}
      <div class="layout__region layout__region--left_sidebar left-sidebar">
      <div class="field-label">{{ "More on"|t }}</div>
        {{ content.left_sidebar }}
    </div>
    {% endif %}

    {% if content.main_content|render %}
      <div {{ region_attributes.main_content.addClass('layout__region', 'layout__region--full', 'main-content', 'margin-bottom-xl') }}>
      {{ content.main_content }}
        {% if content.byline|render and not template_class %}
          {% set shownHeader = false %}
          {% if node and node.hasField('field_authors') and not node.get('field_authors').isEmpty() %}
            {% for item in node.get('field_authors') %}
              {% set author = item.entity %}

              {# Only show internal authors (they have field_person) #}
              {% if author and author.hasField('field_person') and not author.get('field_person').isEmpty() %}
                {% if not shownHeader %}
                <div class="mt-8 mb-2 utility-md font-bold">{{ 'About the Authors:'|t }}</div>
                {% set shownHeader = true %}
                {% endif %}
                <div class="more-author-info">{{ drupal_entity('wri_author', item.target_id, 'listing') }}</div>
              {% endif %}
            {% endfor %}
          {% endif %}

        {% endif %}
        {% if image_attribution and template_class %}
          <div class="more-author-info"><p>{{ image_attribution }}</p></div>
        {% endif %}
        {% if content.bundle|render and (template_class is not empty or region_display_value == 'half-content') %}
          <div class="mt-8">{{ content.bundle|without('addtoany', 'field_relevant_project') }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if content.right_sidebar|render %}
    <div {{ region_attributes.right_sidebar.addClass('layout__region', 'layout__region--right_sidebar', 'right-sidebar-wide') }}>
    {{ content.right_sidebar }}
    </div>
    {% endif %}
  </div>
</div>
{% endif %}
