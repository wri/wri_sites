<?php

/**
 * @file
 * The wri_spoke module.
 */

use Drupal\Core\Entity\ContentEntityInterface;

/**
 * Implements hook_page_attachments().
 */
function wri_spoke_page_attachments(array &$attachments): void {
  /** @var \Drupal\Core\Routing\AdminContext $admin_context */
  $admin_context = \Drupal::service('router.admin_context');
  if ($admin_context->isAdminRoute()) {
    return;
  }

  $attachments['#attached']['library'][] = 'wri_spoke/return_to';
}

/**
 * Implements hook_entity_type_insert().
 */
function wri_spoke_taxonomy_term_insert(ContentEntityInterface $entity): void {
  // If just made a new term that exactly matches one of the "Hub" terms,
  // set the new term's UUID to be the hub's UUID and delete the hubterm.
  $name = $entity->getName();
  $vocabulary = 'hub_terms';
  $original_vocabulary = $entity->bundle();
  if ($name && $vocabulary && $original_vocabulary !== $vocabulary) {
    $entity_query = \Drupal::entityQuery('taxonomy_term');
    $entity_query
      ->condition('name', $name)
    // Condition on an entity property (content type)
      ->condition('vid', $vocabulary)
    // Condition on a custom field value.
      ->condition('field_original_vocabulary', $original_vocabulary)
    // Explicitly enable access checks (recommended)
      ->accessCheck(TRUE);

    // Execute the query to get entity IDs.
    $hub_terms = $entity_query->execute();
    if (!empty($hub_terms)) {
      $hub_term_id = reset($hub_terms);
      $hub_term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($hub_term_id);
      // Also move over any translations of the hub term to be translations of
      // the current term.
      $languages = $hub_term->getTranslationLanguages();
      // Iterate over each language and get the specific translation object.
      foreach ($languages as $langcode => $language) {
        if ($langcode === $hub_term->language()->getId()) {
          $entity->set('name', $hub_term->getName());
        }
        elseif ($hub_term->hasTranslation($language->getId())) {
          $translation = $hub_term->getTranslation($language->getId());
          $translation->delete();

          $entity->addTranslation($langcode, [
            'name' => $translation->getName(),
            'uuid' => $translation->uuid(),
          ]);
        }
      }

      // Then delete the hub term.
      $hub_term->delete();

      $entity->set('uuid', $hub_term->uuid());
      $entity->save();
    }
  }
}
